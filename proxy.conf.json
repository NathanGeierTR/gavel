{
  "/github-api/**": {
    "target": "https://api.github.com",
    "secure": true,
    "changeOrigin": true,
    "pathRewrite": {
      "^/github-api": ""
    },
    "headers": {
      "User-Agent": "gavel"
    }
  },
  "/ado-api/**": {
    "target": "https://dev.azure.com",
    "secure": true,
    "changeOrigin": true,
    "logLevel": "debug",
    "pathRewrite": {
      "^/ado-api": ""
    },
    "onProxyReq": "function(proxyReq, req, res) { console.log('Proxying request to: ' + proxyReq.path); }",
    "onError": "function(err, req, res) { console.log('Proxy error: ' + err); }"
  },
  "/linear-api/**": {
    "target": "https://api.linear.app",
    "secure": false,
    "changeOrigin": true,
    "pathRewrite": {
      "^/linear-api": ""
    }
  },
  "/slack-api/**": {
    "target": "https://slack.com/api",
    "secure": false,
    "changeOrigin": true,
    "pathRewrite": {
      "^/slack-api": ""
    }
  }
}